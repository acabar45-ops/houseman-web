---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import FinalCTA from '../components/FinalCTA.astro';
import PricingPlans from '../components/PricingPlans.astro';
import SaasUIMockup from '../components/SaasUIMockup.astro';

const setupSteps = [
  {
    step: '01',
    duration: '약 3분',
    title: '질문지 작성',
    body: '건물 유형, 호실 수, 현재 청구 방식, 수금 채널, 특이 룰, 연락 선호도 — 20문항 내외의 질문지를 채워주세요.',
    items: ['건물 구조·유형', '호실별 계약 조건', '청구·알림·정산 룰', '하우스맨 확인용 자료 업로드'],
  },
  {
    step: '02',
    duration: '5~10영업일',
    title: '하우스맨이 하드코딩',
    body: '공통 OS 위에 당신 건물의 룰을 코드로 반영합니다. 청구 공식, 알림 시점·문구, 정산 분배 방식, 특수 케이스까지.',
    items: ['건물별 설정 레이어 구축', '기존 데이터 이관 (엑셀/PDF/스캔)', '테스트 환경에서 청구·알림 검증', '이관 완료 후 최종 확인'],
  },
  {
    step: '03',
    duration: '1시간 교육 + 30일 밀착',
    title: '이관 & 운영 시작',
    body: '실제 계정으로 로그인해 시연 교육을 받고, 첫 달은 하우스맨이 바로 옆에서 지원합니다.',
    items: ['담당자 1시간 교육 (온/오프라인)', '첫 청구·정산 사이클 함께 운영', '카톡 핫라인 30일', '이후 월 1회 정기 점검'],
  },
] as const;

const customExamples = [
  {
    building: '강남 A 사옥 (상가 + 오피스)',
    rule: '월세는 기본, 관리비는 월매출 연동, 공과금은 면적 배분',
    impact: '기존 수기 계산 3시간 → 매월 자동 2분',
  },
  {
    building: '역삼 B 원룸 (단기임대)',
    rule: '3개월 계약, 보증금 없음, 일할 정산, 체크인일에 알림톡',
    impact: '미수금 0원 · 공실일 평균 4일 단축',
  },
  {
    building: '논현 C 빌딩 (다중 건물주)',
    rule: '지분 40:35:25, 각 건물주에게 월별 자동 분배 이체',
    impact: '분배 계산·이체 20분 → 버튼 한 번 (0분)',
  },
];

const kakaoTemplates = [
  '[하우스맨] 이번 달 월세 청구서가 도착했습니다. 납부 기한은 ○월 ○일입니다.',
  '[하우스맨] 납부가 확인되었습니다. 감사합니다.',
  '[하우스맨] 납부 기한이 지났습니다. 빠른 시일 내 납부 부탁드립니다.',
  '[하우스맨] 퇴실 예정일이 다가왔습니다. 원상복구 확인 부탁드립니다.',
  '[하우스맨] 긴급 A/S 접수가 완료되었습니다. 담당자가 곧 연락드립니다.',
];

const faqs = [
  {
    q: '왜 셋업비가 필요한가요?',
    a: '건물 관리 룰이 건물마다 완전히 달라 범용 SaaS로는 실제 업무가 안 됩니다. 하우스맨은 질문지 기반으로 당신 건물의 룰을 코드에 직접 반영하는 맞춤 개발비입니다. 30~100만원 범위 내에서 복잡도에 따라 결정됩니다.',
  },
  {
    q: '셋업 기간 동안 기존 관리는 어떻게 하나요?',
    a: '이관 완료 전까지 기존 방식(엑셀/수기/다른 툴)을 그대로 쓰시면 됩니다. 병행 운영 1주일 동안 하우스맨 OS 데이터가 기존과 일치하는지 검증한 후 최종 전환합니다.',
  },
  {
    q: '룰이 바뀌면 또 셋업비를 내야 하나요?',
    a: '경미한 수정(문구·시점·단가)은 무료 지원. 큰 로직 변경은 시간당 5만원 기준으로 견적 드립니다. 분기당 1회 정기 리뷰·조정은 무료입니다.',
  },
  {
    q: '임차인이 앱을 설치해야 하나요?',
    a: '아닙니다. 임차인은 카톡 알림톡만 받습니다. 건물주·관리자만 하우스맨 OS 웹에 로그인해서 관리합니다.',
  },
  {
    q: '해지하면 데이터는?',
    a: '언제든 CSV/엑셀로 내보내기 가능. 해지 후 30일간 데이터 보존, 이 기간 내 재계약 시 그대로 복구됩니다.',
  },
  {
    q: 'SaaS만 써도 되나요? 아니면 대행도 꼭 해야 하나요?',
    a: '독립 상품입니다. OS만 쓰고 건물주가 직접 운영하셔도 되고, 대행도 같이 의뢰하셔도 됩니다. 조합 자유.',
  },
];
---

<BaseLayout
  title="하우스맨 OS — 건물별 맞춤 관리 시스템"
  description="범용 SaaS가 못한 걸 합니다. 질문지 기반으로 당신 건물 룰을 하드코딩. 셋업비 30~100만원 + 호실당 월 3천원."
>
  <Nav />

  <!-- 히어로 -->
  <section class="relative overflow-hidden bg-hero-gradient text-white py-24 md:py-32">
    <div class="hero-wave-dark"></div>
    <div class="relative container-narrow grid md:grid-cols-5 gap-10 items-center">
      <div class="md:col-span-3">
        <p class="eyebrow text-white/70 mb-5">
          <span class="inline-block w-1.5 h-1.5 rounded-full bg-white/80 mr-2 align-middle"></span>
          HOUSEMAN OS
        </p>
        <h1 class="font-display text-display-xl tracking-tight mb-6">
          범용 SaaS가 못한 걸,<br/>
          <span class="bg-gradient-to-r from-white via-white/90 to-white/70 bg-clip-text text-transparent">
            하우스맨 OS는 합니다.
          </span>
        </h1>
        <p class="text-body-l text-white/85 leading-relaxed mb-8 max-w-[540px]">
          건물마다 다른 청구·정산·알림 룰, 엑셀로도 SaaS로도 못 풀었습니다.
          하우스맨은 질문지 기반으로 당신 건물의 룰을 코드에 직접 반영합니다.
        </p>
        <div class="flex flex-wrap gap-3">
          <a href="/onboarding" class="btn-primary bg-white !text-navy-700 hover:!bg-ink-soft">
            셋업 견적 받기 (3분) →
          </a>
          <a href="#setup-flow" class="btn-secondary">세팅 3단계 보기</a>
        </div>
      </div>
      <div class="md:col-span-2 hidden md:block">
        <div class="aspect-[4/5] bg-white/10 rounded-card-lg border border-white/20 flex items-center justify-center text-white/50 text-sm backdrop-blur-sm">
          OS 대시보드 스크린샷<br/>(실 데이터 촬영 예정)
        </div>
      </div>
    </div>
  </section>

  <!-- 세팅 3단계 플로우 -->
  <section id="setup-flow" class="container-narrow py-section">
    <div class="text-center mb-14 max-w-2xl mx-auto">
      <p class="eyebrow mb-3">세팅 프로세스</p>
      <h2 class="font-display text-h2 text-ink tracking-tight">
        3분 질문지 → 5~10영업일 세팅 → 운영 시작.
      </h2>
    </div>
    <div class="space-y-5 max-w-4xl mx-auto">
      {setupSteps.map(({ step, duration, title, body, items }) => (
        <div class="bg-white border border-ink-line rounded-card-lg p-8 shadow-card grid md:grid-cols-12 gap-6">
          <div class="md:col-span-3">
            <p class="font-display text-5xl font-extrabold text-navy-700 leading-none">{step}</p>
            <p class="text-xs text-ink-label tracking-wider uppercase mt-3">{duration}</p>
          </div>
          <div class="md:col-span-9">
            <h3 class="font-display text-h3 text-ink mb-3 tracking-tight">{title}</h3>
            <p class="text-body text-ink-body mb-4 leading-relaxed">{body}</p>
            <ul class="grid sm:grid-cols-2 gap-2 text-sm text-ink-body">
              {items.map((it) => (
                <li class="flex gap-2"><span class="text-navy-700 mt-0.5">·</span><span>{it}</span></li>
              ))}
            </ul>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- 실제 하드코딩 사례 -->
  <section class="bg-ink-soft py-section">
    <div class="container-narrow max-w-5xl">
      <div class="text-center mb-12">
        <p class="eyebrow mb-3">하드코딩 사례</p>
        <h2 class="font-display text-h2 text-ink tracking-tight">
          실제로 이렇게 반영됩니다.
        </h2>
        <p class="mt-3 text-sm text-ink-label">* 건물명은 가명 처리</p>
      </div>
      <div class="space-y-4">
        {customExamples.map(({ building, rule, impact }) => (
          <div class="bg-white border border-ink-line rounded-card-lg p-6 md:p-7 shadow-card grid md:grid-cols-12 gap-5 items-center">
            <div class="md:col-span-3">
              <p class="font-semibold text-ink">{building}</p>
            </div>
            <div class="md:col-span-6">
              <p class="text-sm text-ink-body"><strong class="text-ink">룰:</strong> {rule}</p>
            </div>
            <div class="md:col-span-3">
              <p class="text-sm text-navy-700 font-semibold">→ {impact}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 이관 후 사용 화면 -->
  <SaasUIMockup />

  <!-- 알림톡 5종 -->
  <section class="bg-ink-soft py-section">
    <div class="container-narrow max-w-3xl">
      <div class="text-center mb-12">
        <p class="eyebrow mb-3">알림톡 템플릿</p>
        <h2 class="font-display text-h2 text-ink tracking-tight">
          임차인이 받는 실제 카톡.
        </h2>
      </div>
      <div class="space-y-3">
        {kakaoTemplates.map((text) => (
          <div class="bg-white rounded-card p-4 border border-ink-line flex items-start gap-3">
            <span class="w-2 h-2 rounded-full bg-yellow-400 mt-2 flex-shrink-0"></span>
            <p class="text-sm text-ink leading-relaxed">{text}</p>
          </div>
        ))}
      </div>
      <p class="text-center text-xs text-ink-label mt-6">
        ※ 호실·금액·날짜·문구는 건물별 하드코딩으로 완전 맞춤
      </p>
    </div>
  </section>

  <PricingPlans />

  <!-- FAQ -->
  <section class="container-narrow py-section max-w-3xl">
    <div class="text-center mb-10">
      <p class="eyebrow mb-3">OS FAQ</p>
      <h2 class="font-display text-h2 text-ink tracking-tight">자주 묻는 질문</h2>
    </div>
    <div class="space-y-3">
      {faqs.map(({ q, a }) => (
        <details class="card group">
          <summary class="flex items-center justify-between cursor-pointer list-none">
            <span class="font-semibold text-ink">{q}</span>
            <span class="text-navy-700 text-xl transition-transform group-open:rotate-45">+</span>
          </summary>
          <p class="mt-4 text-ink-body leading-relaxed text-[15px]">{a}</p>
        </details>
      ))}
    </div>
  </section>

  <FinalCTA />
  <Footer />
</BaseLayout>
