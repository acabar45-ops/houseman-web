---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const stores = [
  { label: 'App Store', desc: 'iPhone·iPad', href: '#', badge: 'iOS' },
  { label: 'Google Play', desc: 'Android', href: '#', badge: 'Android' },
  { label: '웹 브라우저', desc: '즉시 사용', href: 'https://app.houseman.co.kr', badge: 'Web' },
];

const features = [
  { icon: '📱', title: 'QR 민원 접수', body: '임차인이 건물 입구 QR 스캔 → 즉시 민원 등록 → 담당자 알림' },
  { icon: '🏢', title: '건물별 대시보드', body: '소유 건물의 수익·공실·미납을 한 화면에' },
  { icon: '💬', title: '알림톡 실시간', body: '발송·수신·독촉 로그 앱에서 즉시 확인' },
  { icon: '📊', title: '월 정산 리포트', body: '매월 말 PDF 자동 생성, 앱에서 열람·다운로드' },
];
---

<BaseLayout
  title="하우스맨 앱 다운로드 | iOS·Android·Web"
  description="하우스맨 SaaS 앱 — iOS·Android·웹 브라우저에서 사용 가능. QR 민원 접수·건물 대시보드·알림톡 로그."
>
  <Nav />

  <section class="bg-hero-gradient text-white py-20">
    <div class="container-narrow max-w-3xl text-center">
      <p class="label-uppercase text-white/70 mb-4">앱 다운로드</p>
      <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight mb-5">
        주머니 속 건물관리
      </h1>
      <p class="text-lg text-white/85 leading-relaxed">
        건물주·담당자·임차인 모두 한 앱으로.<br/>
        원하는 곳에서 설치해 바로 사용하세요.
      </p>
    </div>
  </section>

  <!-- 스토어 3종 -->
  <section class="container-narrow py-section max-w-4xl">
    <div class="grid md:grid-cols-3 gap-5">
      {stores.map(({ label, desc, href, badge }) => (
        <a href={href} class="card hover:border-navy-700 transition text-center">
          <div class="label-uppercase mb-3">{badge}</div>
          <h3 class="text-lg font-bold text-navy-700 mb-1">{label}</h3>
          <p class="text-sm text-ink-muted mb-5">{desc}</p>
          <div class="inline-block px-5 py-2 rounded-card bg-navy-700 text-white text-sm font-semibold">
            바로 열기
          </div>
        </a>
      ))}
    </div>
    <p class="text-center text-xs text-ink-label mt-8">
      ※ iOS·Android 스토어 앱은 2026년 하반기 출시 예정. 현재는 웹으로 바로 이용 가능.
    </p>
  </section>

  <!-- 앱만의 기능 -->
  <section class="bg-ink-soft py-section">
    <div class="container-narrow max-w-5xl">
      <div class="text-center mb-12">
        <p class="label-uppercase mb-3">앱 기능</p>
        <h2 class="text-3xl md:text-4xl font-bold text-navy-700">
          모바일에서 더 편한 기능
        </h2>
      </div>
      <div class="grid md:grid-cols-2 gap-5">
        {features.map(({ icon, title, body }) => (
          <div class="card">
            <div class="text-2xl mb-3">{icon}</div>
            <h3 class="font-bold text-navy-700 mb-2">{title}</h3>
            <p class="text-sm text-ink-muted leading-relaxed">{body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
