---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import FinalCTA from '../../components/FinalCTA.astro';
import { fetchPosts, type WPPost } from '../../lib/wp.ts';

export async function getStaticPaths() {
  try {
    const posts = await fetchPosts({ perPage: 100 });
    return posts.map((post) => ({
      params: { slug: post.slug },
      props: { post },
    }));
  } catch {
    return [];
  }
}

const { post } = Astro.props as { post: WPPost };

// fallback — WP 미세팅 시 placeholder 데이터
const title = post?.title?.rendered ?? '글 제목';
const content = post?.content?.rendered ?? '<p>본문 내용. 블로그 운영 시작 후 실제 글이 표시됩니다.</p>';
const date = post?.date ?? '';
const categoryName =
  post?._embedded?.['wp:term']?.[0]?.[0]?.name ?? '미분류';
const featuredImage =
  post?._embedded?.['wp:featuredmedia']?.[0]?.source_url ?? null;
---

<BaseLayout title={`${title} | 하우스맨 블로그`} description={title}>
  <Nav />

  <article class="container-narrow py-section max-w-3xl">
    <div class="mb-8">
      <a href="/blog" class="text-sm text-ink-muted hover:text-navy-700">
        ← 블로그 목록
      </a>
    </div>

    <div class="label-uppercase mb-4">{categoryName}</div>
    <h1 class="text-3xl md:text-5xl font-extrabold text-navy-700 leading-tight tracking-tight mb-6" set:html={title}></h1>
    <time class="text-sm text-ink-label block mb-10">
      {date && new Date(date).toLocaleDateString('ko-KR')}
    </time>

    {featuredImage && (
      <img src={featuredImage} alt="" class="w-full rounded-card mb-10" />
    )}

    <div
      class="prose prose-neutral max-w-none
             prose-headings:text-navy-700 prose-headings:font-bold
             prose-h2:text-2xl prose-h2:mt-10 prose-h2:mb-4
             prose-h3:text-xl prose-h3:mt-8 prose-h3:mb-3
             prose-p:text-ink prose-p:leading-relaxed
             prose-a:text-navy-700 prose-a:no-underline hover:prose-a:underline
             prose-strong:text-navy-700
             prose-blockquote:border-navy-700 prose-blockquote:text-ink-muted"
      set:html={content}
    >
    </div>

    <!-- 공유 버튼 -->
    <div class="mt-16 pt-8 border-t border-ink-line">
      <p class="label-uppercase mb-4">공유하기</p>
      <div class="flex flex-wrap gap-2">
        <button
          data-share="copy"
          class="share-btn"
          type="button"
        >
          🔗 링크 복사
        </button>
        <a
          href={`https://share.naver.com/web/shareView?url=${encodeURIComponent(Astro.url.href)}&title=${encodeURIComponent(title)}`}
          target="_blank"
          rel="noopener"
          class="share-btn"
        >
          N 네이버 공유
        </a>
        <a
          href={`https://twitter.com/intent/tweet?url=${encodeURIComponent(Astro.url.href)}&text=${encodeURIComponent(title)}`}
          target="_blank"
          rel="noopener"
          class="share-btn"
        >
          X 공유
        </a>
      </div>
    </div>

    <!-- 작성자 카드 -->
    <aside class="mt-10 card bg-ink-soft">
      <div class="flex items-center gap-4">
        <div class="w-12 h-12 rounded-full bg-navy-700 text-white flex items-center justify-center font-extrabold text-xl">
          H
        </div>
        <div>
          <div class="font-bold text-navy-700">하우스맨 편집부</div>
          <div class="text-xs text-ink-muted mt-1">
            2012년부터 서울 강남 기반 100+ 건물 1,100+ 호실 운영 경험
          </div>
        </div>
      </div>
    </aside>
  </article>

  <style>
    .share-btn {
      @apply inline-flex items-center gap-1 px-4 py-2 text-sm font-semibold
             border border-ink-line rounded-full text-ink-muted
             hover:border-navy-700 hover:text-navy-700 transition cursor-pointer;
    }
  </style>

  <script is:inline>
    document.querySelectorAll('[data-share="copy"]').forEach((btn) => {
      btn.addEventListener('click', async () => {
        try {
          await navigator.clipboard.writeText(window.location.href);
          const original = btn.textContent;
          btn.textContent = '✓ 복사됨';
          setTimeout(() => { btn.textContent = original; }, 1800);
        } catch (e) {
          alert('복사 실패: 주소를 수동으로 복사해주세요.');
        }
      });
    });
  </script>

  <FinalCTA />
  <Footer />
</BaseLayout>
