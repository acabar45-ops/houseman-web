---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const quickLinks = [
  { href: '/services/short-term', label: '단기임대 운영' },
  { href: '/services/buildings', label: '중소형 빌딩' },
  { href: '/services/housing', label: '중소형 주택' },
  { href: '/saas', label: 'SaaS 플랫폼' },
  { href: '/pricing', label: '요금제' },
  { href: '/vacancies', label: '공실 정보' },
  { href: '/blog', label: '블로그' },
  { href: '/contact', label: '문의' },
];
---

<BaseLayout
  title="페이지를 찾을 수 없습니다 | 하우스맨"
  description="요청하신 페이지가 존재하지 않거나 이동되었습니다."
>
  <Nav />

  <section class="container-narrow py-section text-center max-w-2xl">
    <p class="label-uppercase mb-4 text-emphasis">404</p>
    <h1 class="text-4xl md:text-6xl font-extrabold text-navy-700 tracking-tight mb-5">
      이 페이지는<br/>OS에 없네요.
    </h1>
    <p class="text-lg text-ink-muted leading-relaxed mb-10">
      요청하신 페이지를 찾을 수 없습니다.<br/>
      아래 경로로 다시 안내해드릴게요.
    </p>

    <div class="flex flex-wrap justify-center gap-3 mb-10">
      <a href="/" class="btn-primary">홈으로</a>
      <a href="tel:1544-4150" class="btn-ghost">1544-4150 상담</a>
      <a
        href="https://pf.kakao.com/_hYmxjn/chat"
        target="_blank"
        rel="noopener"
        class="btn-ghost"
      >
        카톡 문의
      </a>
    </div>

    <div class="card text-left">
      <p class="label-uppercase mb-4">자주 찾는 페이지</p>
      <div class="grid grid-cols-2 gap-3">
        {quickLinks.map(({ href, label }) => (
          <a
            href={href}
            class="flex items-center justify-between px-3 py-2 rounded border border-ink-line hover:border-navy-700 hover:text-navy-700 text-sm"
          >
            <span>{label}</span>
            <span class="text-ink-label">→</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
