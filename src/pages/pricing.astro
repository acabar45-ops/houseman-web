---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import FinalCTA from '../components/FinalCTA.astro';
import PricingPlans from '../components/PricingPlans.astro';

const comparison = [
  { feature: '호실 수용', starter: '1~10 호실', pro: '11~50 호실', ent: '50+ 호실' },
  { feature: '자동 청구', starter: '✓', pro: '✓', ent: '✓' },
  { feature: '기본 대시보드', starter: '✓', pro: '✓', ent: '✓' },
  { feature: '알림톡 기본', starter: '✓', pro: '✓', ent: '✓' },
  { feature: '알림톡 3단계 독촉', starter: '—', pro: '✓', ent: '✓' },
  { feature: '검침 자동화', starter: '—', pro: '✓', ent: '✓' },
  { feature: '자동 정산 분배', starter: '—', pro: '✓', ent: '✓' },
  { feature: '미납 회수 지원', starter: '—', pro: '✓', ent: '✓' },
  { feature: '긴급 출동', starter: '—', pro: '—', ent: '✓' },
  { feature: '법무 지원', starter: '—', pro: '—', ent: '✓' },
  { feature: '전담 매니저', starter: '—', pro: '—', ent: '✓' },
  { feature: '기업 시설 관리', starter: '—', pro: '—', ent: '✓' },
];

const agencyFactors = [
  { icon: '🏢', title: '건물 크기·유형', body: '주거·상업·단기·복합 유형과 호실 수에 따라 결정' },
  { icon: '📋', title: '서비스 범위', body: '청구만·풀패키지·법무 포함 등 선택에 따라 차등' },
  { icon: '🚑', title: '긴급 출동', body: '24시간 긴급 대응 포함 여부' },
  { icon: '👥', title: '전담 인력', body: '건물 담당자·시설팀·민원 창구 별도 배정 여부' },
];

const faqs = [
  {
    q: '14일 체험 이후 자동 결제되나요?',
    a: '자동 전환되지 않습니다. 체험 기간 종료 전에 직접 플랜을 선택하셔야 결제가 시작됩니다.',
  },
  {
    q: '중간에 플랜 변경 가능한가요?',
    a: '네. Starter → Pro → Enterprise 언제든 업그레이드 가능. 다운그레이드는 다음 결제 주기에 반영.',
  },
  {
    q: '대행 수수료는 얼마인가요?',
    a: '맞춤 견적입니다. 건물 크기·서비스 범위에 따라 월 수십만 원부터 수백만 원대까지 다양합니다. 1544-4150으로 상담 요청 주시면 15분 내 예상 견적을 드립니다.',
  },
  {
    q: 'VAT는 별도인가요?',
    a: 'SaaS·대행 서비스 모두 VAT 별도입니다. 세금계산서 발행 가능.',
  },
];
---

<BaseLayout
  title="요금제 | 하우스맨"
  description="SaaS는 월 3만원부터 공개. 대행은 건물 크기·서비스 범위별 맞춤 견적. 14일 무료 체험."
>
  <Nav />

  <section class="bg-hero-gradient text-white py-20">
    <div class="container-narrow text-center max-w-3xl">
      <p class="label-uppercase text-white/70 mb-4">요금제</p>
      <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight mb-5">
        투명한 가격, 숨김 없음.
      </h1>
      <p class="text-lg text-white/85 leading-relaxed">
        SaaS 가격은 공개, 대행 서비스는 맞춤 견적.
      </p>
    </div>
  </section>

  <PricingPlans />

  <!-- 기능 비교표 -->
  <section class="container-narrow py-section">
    <div class="text-center mb-10">
      <p class="label-uppercase mb-3">기능 비교</p>
      <h2 class="text-2xl md:text-3xl font-bold text-navy-700">
        플랜별 포함 기능
      </h2>
    </div>
    <div class="card p-0 overflow-hidden max-w-4xl mx-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="bg-ink-soft">
            <th class="text-left py-4 px-5 label-uppercase">기능</th>
            <th class="text-center py-4 px-4 label-uppercase">Starter</th>
            <th class="text-center py-4 px-4 label-uppercase text-navy-700">Pro</th>
            <th class="text-center py-4 px-4 label-uppercase">Enterprise</th>
          </tr>
        </thead>
        <tbody>
          {comparison.map((row, i) => (
            <tr class={i < comparison.length - 1 ? 'border-b border-ink-line' : ''}>
              <td class="py-3 px-5 font-medium text-ink">{row.feature}</td>
              <td class="py-3 px-4 text-center text-ink-muted">{row.starter}</td>
              <td class="py-3 px-4 text-center text-navy-700 font-semibold">{row.pro}</td>
              <td class="py-3 px-4 text-center text-ink">{row.ent}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <!-- 대행 산정 기준 -->
  <section class="bg-ink-soft py-section">
    <div class="container-narrow max-w-4xl">
      <div class="text-center mb-10">
        <p class="label-uppercase mb-3">대행 서비스</p>
        <h2 class="text-2xl md:text-3xl font-bold text-navy-700">
          대행은 맞춤 견적입니다. 이런 요소로 결정됩니다.
        </h2>
      </div>
      <div class="grid md:grid-cols-2 gap-5">
        {agencyFactors.map(({ icon, title, body }) => (
          <div class="card">
            <div class="text-2xl mb-3">{icon}</div>
            <h3 class="text-lg font-bold text-ink mb-2">{title}</h3>
            <p class="text-sm text-ink-muted leading-relaxed">{body}</p>
          </div>
        ))}
      </div>
      <div class="text-center mt-10">
        <a href="tel:1544-4150" class="btn-primary">
          맞춤 견적 받기 1544-4150
        </a>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="container-narrow py-section max-w-3xl">
    <div class="text-center mb-10">
      <p class="label-uppercase mb-3">요금제 FAQ</p>
      <h2 class="text-2xl md:text-3xl font-bold text-navy-700">자주 묻는 질문</h2>
    </div>
    <div class="space-y-3">
      {faqs.map(({ q, a }) => (
        <details class="card group">
          <summary class="flex items-center justify-between cursor-pointer list-none">
            <span class="font-semibold text-ink">{q}</span>
            <span class="text-navy-700 text-xl transition-transform group-open:rotate-45">+</span>
          </summary>
          <p class="mt-4 text-ink-muted leading-relaxed text-[15px]">{a}</p>
        </details>
      ))}
    </div>
  </section>

  <FinalCTA />
  <Footer />
</BaseLayout>
