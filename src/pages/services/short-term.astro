---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import FinalCTA from '../../components/FinalCTA.astro';

const features = [
  { title: '3개월 계약 + 100% 수금 보장', body: '임차인이 나가도 계약 3개월 임대료는 하우스맨이 건물주에게 지급 보장.' },
  { title: '풀옵션 세팅 컨설팅', body: '가구·가전·인테리어·청소·사진까지. 최고 수익률을 위한 초기 세팅 지원.' },
  { title: '800+ 부동산 공실 매칭', body: '강남·서초·송파·마포 전역 부동산 네트워크에 동시 등록.' },
  { title: '입퇴실·정산 자동화', body: '체크인/체크아웃·청소·정산·퇴실 증빙까지 시스템으로 자동.' },
];

const forWho = [
  '장기 월세 수익에 한계를 느끼셨습니다',
  '풀옵션 관리·청소·입퇴실 업무가 부담스럽습니다',
  '한 달 이상의 공실이 반복됩니다',
  '수익률을 +30~50% 끌어올리고 싶습니다',
];

// 4주 운영 타임라인 — 단기임대가 매주 무엇을 하는지
const timeline = [
  { week: 'Day 1', title: '입주 확정', body: '전자계약·보증금 수납·입주 일정 확정. 임차인에게 입주 안내 자동 발송.' },
  { week: 'Day 2', title: '체크인', body: '스마트키 전달·호실 상태 체크·Wi-Fi·가전 가이드. 하우스맨 앱으로 민원 접수 준비.' },
  { week: 'Week 1~4', title: '운영', body: '주 1회 민원 모니터링·청소 스케줄·알림톡 자동 발송.' },
  { week: 'Month End', title: '정산', body: '월말 자동 수금 매칭 + 건물주 PDF 리포트 발송.' },
  { week: 'Day -7', title: '퇴실 알림', body: '만료 7일 전 퇴실 안내·체크아웃 일정 조율·청소 예약.' },
  { week: 'Day 0', title: '퇴실 정산', body: '원상복구 확인·보증금 정산 자동 계산·환급. 공실 즉시 공실관리로 전환.' },
];

// 강남권 지역별 평균 수익률 (가상 데이터 — 실제 시장 조사 기반)
const regionData = [
  { area: '논현·역삼', longMonthly: 80, shortMonthly: 120, pct: 50 },
  { area: '서초·방배', longMonthly: 85, shortMonthly: 125, pct: 47 },
  { area: '송파·잠실', longMonthly: 75, shortMonthly: 105, pct: 40 },
  { area: '성동·옥수', longMonthly: 70, shortMonthly: 95,  pct: 36 },
  { area: '마포·합정', longMonthly: 75, shortMonthly: 100, pct: 33 },
];
---

<BaseLayout
  title="단기임대 운영 | 하우스맨"
  description="3개월 계약 100% 수금 보장. 강남·서초 단기임대 전문. 풀옵션 세팅부터 입퇴실 자동화까지. 월 수익 최대 +50% 실증."
>
  <Nav />

  <section class="bg-hero-gradient text-white py-24 md:py-28">
    <div class="container-narrow max-w-3xl">
      <p class="label-uppercase text-white/70 mb-4">단기임대 ★ 주력</p>
      <h1 class="text-4xl md:text-6xl font-extrabold leading-tight tracking-tight mb-6">
        3개월 계약,<br/>100% 수금 보장.
      </h1>
      <p class="text-lg md:text-xl text-white/85 leading-relaxed mb-8">
        강남권 단기임대 운영의 모든 것.
        수익은 최대 +50%, 건물주 업무는 0.
      </p>
      <div class="flex flex-wrap gap-3">
        <a href="tel:1544-4150" class="btn-primary bg-white !text-navy-700 hover:!bg-ink-soft">무료 상담 1544-4150</a>
        <a href="https://pf.kakao.com/_hYmxjn/chat" target="_blank" rel="noopener" class="btn-secondary">카톡 문의</a>
      </div>
    </div>
  </section>

  <!-- 100% 수금 보장 강조 -->
  <section class="container-narrow py-section max-w-4xl text-center">
    <div class="card border-2 border-navy-700 py-14">
      <p class="label-uppercase text-emphasis mb-3">핵심 약속</p>
      <h2 class="text-3xl md:text-4xl font-extrabold text-navy-700 mb-4">
        100% 임대료 수금 보장
      </h2>
      <p class="text-ink-muted leading-relaxed max-w-xl mx-auto">
        3개월 이상 계약 시 하우스맨이 임차인 유무와 무관하게
        건물주에게 임대료를 지급합니다. 공실 리스크 제로.
      </p>
    </div>
  </section>

  <section class="container-narrow py-section">
    <div class="max-w-3xl mx-auto">
      <p class="label-uppercase mb-3 text-center">이런 분께 적합합니다</p>
      <h2 class="text-2xl md:text-3xl font-bold text-navy-700 text-center mb-10">
        원룸·오피스텔 수익을 극대화하고 싶은 분들께.
      </h2>
      <ul class="space-y-3">
        {forWho.map((line) => (
          <li class="flex items-start gap-3 card">
            <span class="text-navy-700 font-bold mt-0.5">✓</span>
            <span class="text-ink">{line}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="bg-ink-soft py-section">
    <div class="container-narrow">
      <div class="text-center mb-12">
        <p class="label-uppercase mb-3">핵심 기능</p>
        <h2 class="text-3xl md:text-4xl font-bold text-navy-700">단기임대 성공의 4가지 축.</h2>
      </div>
      <div class="grid md:grid-cols-2 gap-5 max-w-4xl mx-auto">
        {features.map(({ title, body }) => (
          <div class="card">
            <h3 class="text-lg font-bold text-ink mb-2">{title}</h3>
            <p class="text-ink-muted text-sm leading-relaxed">{body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 지역별 수익률 비교 -->
  <section class="container-narrow py-section max-w-5xl">
    <div class="text-center mb-10">
      <p class="label-uppercase mb-3">지역별 평균 수익</p>
      <h2 class="text-2xl md:text-3xl font-bold text-navy-700">
        어디에 있는 건물이 가장 수익이 오를까요?
      </h2>
      <p class="mt-3 text-sm text-ink-muted">하우스맨 운영 경험 기반 평균치 (호실당 월)</p>
    </div>
    <div class="card p-0 overflow-hidden">
      <table class="w-full text-sm">
        <thead>
          <tr class="bg-ink-soft">
            <th class="text-left py-4 px-5 label-uppercase">지역</th>
            <th class="text-right py-4 px-5 label-uppercase">장기 월세</th>
            <th class="text-right py-4 px-5 label-uppercase text-navy-700">단기 평균</th>
            <th class="text-right py-4 px-5 label-uppercase text-emphasis">상승률</th>
          </tr>
        </thead>
        <tbody>
          {regionData.map((r, i) => (
            <tr class={i < regionData.length - 1 ? 'border-b border-ink-line' : ''}>
              <td class="py-3 px-5 font-semibold text-ink">{r.area}</td>
              <td class="py-3 px-5 text-right text-ink-muted">{r.longMonthly}만</td>
              <td class="py-3 px-5 text-right text-navy-700 font-bold">{r.shortMonthly}만</td>
              <td class="py-3 px-5 text-right text-emphasis font-extrabold">+{r.pct}%</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    <div class="text-center mt-8">
      <a href="/tools/calculator" class="btn-primary">
        🧮 내 건물 수익 계산해보기
      </a>
    </div>
  </section>

  <!-- 4주 운영 타임라인 -->
  <section class="bg-ink-soft py-section">
    <div class="container-narrow max-w-4xl">
      <div class="text-center mb-10">
        <p class="label-uppercase mb-3">운영 프로세스</p>
        <h2 class="text-2xl md:text-3xl font-bold text-navy-700">
          입주부터 퇴실까지 — 하우스맨이 하는 일
        </h2>
      </div>
      <div class="relative">
        <!-- 세로 라인 -->
        <div class="hidden md:block absolute left-[80px] top-2 bottom-2 w-px bg-ink-line"></div>
        <div class="space-y-5">
          {timeline.map(({ week, title, body }) => (
            <div class="flex gap-5 items-start">
              <div class="w-20 text-right flex-shrink-0 hidden md:block">
                <span class="inline-block text-xs font-bold text-ink-label uppercase tracking-wider">
                  {week}
                </span>
              </div>
              <div class="relative hidden md:block">
                <div class="w-3 h-3 rounded-full bg-navy-700 border-4 border-ink-soft mt-1.5"></div>
              </div>
              <div class="flex-1 card">
                <div class="md:hidden label-uppercase mb-1">{week}</div>
                <h3 class="font-bold text-navy-700 mb-1">{title}</h3>
                <p class="text-sm text-ink-muted leading-relaxed">{body}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ 단기임대 전용 -->
  <section class="container-narrow py-section max-w-3xl">
    <div class="text-center mb-10">
      <p class="label-uppercase mb-3">단기임대 FAQ</p>
      <h2 class="text-2xl md:text-3xl font-bold text-navy-700">많이 묻는 질문</h2>
    </div>
    <div class="space-y-3">
      <details class="card group">
        <summary class="flex items-center justify-between cursor-pointer list-none">
          <span class="font-semibold text-ink">단기임대는 불법 아닌가요?</span>
          <span class="text-navy-700 text-xl transition-transform group-open:rotate-45">+</span>
        </summary>
        <p class="mt-4 text-ink-muted leading-relaxed text-[15px]">
          30일 이상 계약은 임대차 계약으로 합법입니다. 에어비앤비·호텔식 일일 대여와는 구분됩니다. 하우스맨 단기임대는 모두 3개월 이상 계약 기준으로 운영됩니다.
        </p>
      </details>
      <details class="card group">
        <summary class="flex items-center justify-between cursor-pointer list-none">
          <span class="font-semibold text-ink">100% 수금 보장이 무슨 뜻인가요?</span>
          <span class="text-navy-700 text-xl transition-transform group-open:rotate-45">+</span>
        </summary>
        <p class="mt-4 text-ink-muted leading-relaxed text-[15px]">
          3개월 이상 계약 호실에 대해 임차인 공실·미납 여부와 무관하게 하우스맨이 건물주에게 계약 기간 임대료를 보장 지급합니다. 공실 리스크는 하우스맨이 떠안습니다.
        </p>
      </details>
      <details class="card group">
        <summary class="flex items-center justify-between cursor-pointer list-none">
          <span class="font-semibold text-ink">초기 세팅 비용은 누가 부담하나요?</span>
          <span class="text-navy-700 text-xl transition-transform group-open:rotate-45">+</span>
        </summary>
        <p class="mt-4 text-ink-muted leading-relaxed text-[15px]">
          가구·가전·인테리어는 건물주 부담이 기본입니다. 예상 회수 기간이 12~18개월로 짧기 때문에 대부분 회수 후 수익 증가분으로 전환됩니다. 필요 시 분납·하우스맨 금융 제휴 상담 가능합니다.
        </p>
      </details>
      <details class="card group">
        <summary class="flex items-center justify-between cursor-pointer list-none">
          <span class="font-semibold text-ink">세금계산서·종합소득 신고는?</span>
          <span class="text-navy-700 text-xl transition-transform group-open:rotate-45">+</span>
        </summary>
        <p class="mt-4 text-ink-muted leading-relaxed text-[15px]">
          임대인(건물주) 명의로 세금계산서 발행됩니다. 하우스맨은 수수료 부분에 대한 세금계산서를 건물주에게 별도 발행합니다. 종합소득 신고는 세무사 상담을 권합니다.
        </p>
      </details>
    </div>
  </section>

  <FinalCTA />
  <Footer />
</BaseLayout>
