---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const channels = [
  {
    title: '전화 상담',
    body: '평일 09:00~18:00 (점심 12:00~13:00 제외)\n무료 상담 15분 소요',
    cta: '1544-4150',
    href: 'tel:1544-4150',
    note: '가장 빠른 경로',
  },
  {
    title: '카카오톡 채널',
    body: '메시지 남겨주시면 근무일 내 답변드립니다.\n건물 정보·주소만 있으면 견적 가능',
    cta: '@HOUSEMAN',
    href: 'https://pf.kakao.com/_hYmxjn/chat',
    note: '24시간 접수',
  },
  {
    title: '이메일',
    body: '공식 문의·세금계산서·제안서 등 문서 필요 시',
    cta: 'contact@houseman.co.kr',
    href: 'mailto:contact@houseman.co.kr',
    note: '1영업일 내 회신',
  },
];
---

<BaseLayout
  title="문의 | 하우스맨"
  description="건물관리 상담 문의. 전화 1544-4150, 카톡 채널, 이메일 contact@houseman.co.kr. 서울 강남 본사."
>
  <Nav />

  <section class="bg-hero-gradient text-white py-20">
    <div class="container-narrow text-center max-w-3xl">
      <p class="label-uppercase text-white/70 mb-4">문의</p>
      <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight mb-5">
        무엇을 도와드릴까요?
      </h1>
      <p class="text-lg text-white/85 leading-relaxed">
        건물 정보·주소만 있으면 15분 안에 예상 견적을 드립니다.
      </p>
    </div>
  </section>

  <!-- 3채널 -->
  <section class="container-narrow py-section">
    <div class="grid md:grid-cols-3 gap-5 max-w-5xl mx-auto">
      {channels.map(({ title, body, cta, href, note }) => (
        <a href={href} class="card hover:border-navy-700 transition group block">
          <div class="label-uppercase mb-3">{note}</div>
          <h3 class="text-lg font-bold text-navy-700 mb-3">{title}</h3>
          <p class="text-sm text-ink-muted leading-relaxed whitespace-pre-line mb-5 min-h-[48px]">
            {body}
          </p>
          <div class="pt-4 border-t border-ink-line font-bold text-ink group-hover:text-navy-700">
            {cta} →
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- 문의 폼 (Web3Forms 무료 엔드포인트 — 사장님이 API key 발급 후 교체) -->
  <section class="bg-ink-soft py-section">
    <div class="container-narrow max-w-2xl">
      <div class="text-center mb-8">
        <p class="label-uppercase mb-3">빠른 상담 요청</p>
        <h2 class="text-2xl md:text-3xl font-bold text-navy-700">
          아래 양식을 남겨주세요
        </h2>
        <p class="mt-3 text-sm text-ink-muted">15분 내 회신드립니다 (영업시간 기준)</p>
      </div>

      <form id="contact-form" class="card space-y-4">
        <!-- Web3Forms endpoint (사장님이 https://web3forms.com/ 가입 후 access key 발급 → 환경변수 연결) -->
        <input type="hidden" name="access_key" value="YOUR_WEB3FORMS_KEY" />
        <input type="hidden" name="subject" value="[하우스맨] 홈페이지 문의 접수" />
        <input type="hidden" name="from_name" value="하우스맨 홈페이지" />

        <div class="grid md:grid-cols-2 gap-3">
          <div>
            <label class="block text-sm font-semibold text-ink mb-1">이름 *</label>
            <input name="name" type="text" required
                   placeholder="홍길동"
                   class="w-full px-4 py-3 rounded-card border border-ink-line focus:border-navy-700 focus:outline-none" />
          </div>
          <div>
            <label class="block text-sm font-semibold text-ink mb-1">연락처 *</label>
            <input name="phone" type="tel" required
                   placeholder="010-1234-5678"
                   class="w-full px-4 py-3 rounded-card border border-ink-line focus:border-navy-700 focus:outline-none" />
          </div>
        </div>

        <div>
          <label class="block text-sm font-semibold text-ink mb-1">이메일</label>
          <input name="email" type="email"
                 placeholder="owner@example.com"
                 class="w-full px-4 py-3 rounded-card border border-ink-line focus:border-navy-700 focus:outline-none" />
        </div>

        <div>
          <label class="block text-sm font-semibold text-ink mb-1">관심 서비스</label>
          <select name="service"
                  class="w-full px-4 py-3 rounded-card border border-ink-line focus:border-navy-700 focus:outline-none bg-white">
            <option>중소형 빌딩 관리</option>
            <option>중소형 주택 관리</option>
            <option>단기임대 운영</option>
            <option>기업 시설 관리</option>
            <option>비상주 관리사무소</option>
            <option>SaaS 구독 (직접 관리)</option>
            <option>아직 모르겠음 · 상담 필요</option>
          </select>
        </div>

        <div>
          <label class="block text-sm font-semibold text-ink mb-1">건물 주소 (대략)</label>
          <input name="building_address" type="text"
                 placeholder="서울 강남구 ○○동"
                 class="w-full px-4 py-3 rounded-card border border-ink-line focus:border-navy-700 focus:outline-none" />
        </div>

        <div>
          <label class="block text-sm font-semibold text-ink mb-1">문의 내용</label>
          <textarea name="message" rows="4"
                    placeholder="예) 원룸 15호실, 현재 직접 관리 중인데 미납 대응이 힘들어서 상담 받고 싶습니다."
                    class="w-full px-4 py-3 rounded-card border border-ink-line focus:border-navy-700 focus:outline-none"></textarea>
        </div>

        <label class="flex items-start gap-2 text-xs text-ink-muted leading-relaxed">
          <input type="checkbox" name="consent" required class="mt-0.5" />
          <span>개인정보 수집·이용 동의 (<a href="/privacy" class="underline">자세히</a>)</span>
        </label>

        <!-- 스팸 필터 (봇 차단) -->
        <input type="checkbox" name="botcheck" style="display:none" tabindex="-1" autocomplete="off" />

        <button type="submit" class="btn-primary w-full justify-center">
          상담 요청 보내기
        </button>

        <div id="form-result" class="hidden pt-4">
          <p class="text-center font-semibold text-navy-700">
            ✅ 접수 완료! 15분 내 연락드리겠습니다.
          </p>
        </div>
      </form>
    </div>
  </section>

  <!-- 오시는 길 -->
  <section class="bg-white py-section">
    <div class="container-narrow max-w-4xl">
      <p class="label-uppercase text-center mb-3">본사</p>
      <h2 class="text-2xl md:text-3xl font-bold text-navy-700 text-center mb-10">
        오시는 길
      </h2>
      <div class="card">
        <dl class="grid md:grid-cols-2 gap-5 text-sm">
          <div>
            <dt class="text-ink-muted mb-1">주소</dt>
            <dd class="font-semibold text-ink">서울특별시 강남구 학동로8길 9, 5층</dd>
          </div>
          <div>
            <dt class="text-ink-muted mb-1">대표번호</dt>
            <dd class="font-semibold text-ink">
              <a href="tel:1544-4150">1544-4150</a>
            </dd>
          </div>
          <div>
            <dt class="text-ink-muted mb-1">업무시간</dt>
            <dd class="font-semibold text-ink">평일 09:00~18:00 (점심 12:00~13:00)</dd>
          </div>
          <div>
            <dt class="text-ink-muted mb-1">지하철</dt>
            <dd class="font-semibold text-ink">7호선 학동역 · 3호선 압구정역 도보 거리</dd>
          </div>
        </dl>
      </div>
    </div>
  </section>

  <!-- 회사 정보 요약 -->
  <section class="container-narrow py-section max-w-3xl">
    <div class="card text-center">
      <p class="label-uppercase mb-3">회사 정보</p>
      <div class="text-sm text-ink-muted leading-relaxed space-y-1">
        <div>(주)하우스맨 · 대표 박종호</div>
        <div>사업자등록번호 206-16-25497</div>
        <div>서울특별시 강남구 학동로8길 9, 5층</div>
      </div>
    </div>
  </section>

  <Footer />

  <script is:inline>
    const form = document.getElementById('contact-form');
    const result = document.getElementById('form-result');
    if (form) {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const data = new FormData(form);

        // Web3Forms access_key가 아직 placeholder면 로컬 저장만
        const key = data.get('access_key');
        if (key === 'YOUR_WEB3FORMS_KEY') {
          const leads = JSON.parse(localStorage.getItem('contact_leads') || '[]');
          leads.push(Object.fromEntries(data));
          localStorage.setItem('contact_leads', JSON.stringify(leads));
          console.log('[contact·DRY] Web3Forms 미연결 상태. localStorage 저장:', Object.fromEntries(data));
          result.classList.remove('hidden');
          if (typeof gtag !== 'undefined') {
            gtag('event', 'contact_submit', { service: data.get('service') });
          }
          form.reset();
          return;
        }

        try {
          const res = await fetch('https://api.web3forms.com/submit', {
            method: 'POST', body: data,
          });
          const json = await res.json();
          if (json.success) {
            result.classList.remove('hidden');
            if (typeof gtag !== 'undefined') {
              gtag('event', 'contact_submit', { service: data.get('service') });
            }
            form.reset();
          } else {
            alert('전송 실패: ' + (json.message || '다시 시도해주세요'));
          }
        } catch (err) {
          alert('네트워크 오류. 1544-4150으로 전화 부탁드립니다.');
        }
      });
    }
  </script>
</BaseLayout>
