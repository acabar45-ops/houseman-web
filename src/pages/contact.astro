---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const channels = [
  {
    title: '전화 상담',
    body: '평일 09:00~18:00 (점심 12:00~13:00 제외)\n무료 상담 15분 소요',
    cta: '1544-4150',
    href: 'tel:1544-4150',
    note: '가장 빠른 경로',
  },
  {
    title: '카카오톡 채널',
    body: '메시지 남겨주시면 근무일 내 답변드립니다.\n건물 정보·주소만 있으면 견적 가능',
    cta: '@HOUSEMAN',
    href: 'https://pf.kakao.com/_hYmxjn/chat',
    note: '24시간 접수',
  },
  {
    title: '이메일',
    body: '공식 문의·세금계산서·제안서 등 문서 필요 시',
    cta: 'contact@houseman.co.kr',
    href: 'mailto:contact@houseman.co.kr',
    note: '1영업일 내 회신',
  },
];
---

<BaseLayout
  title="문의 | 하우스맨"
  description="건물관리 상담 문의. 전화 1544-4150, 카톡 채널, 이메일 contact@houseman.co.kr. 서울 강남 본사."
>
  <Nav />

  <section class="bg-hero-gradient text-white py-20">
    <div class="container-narrow text-center max-w-3xl">
      <p class="label-uppercase text-white/70 mb-4">문의</p>
      <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight mb-5">
        무엇을 도와드릴까요?
      </h1>
      <p class="text-lg text-white/85 leading-relaxed">
        건물 정보·주소만 있으면 15분 안에 예상 견적을 드립니다.
      </p>
    </div>
  </section>

  <!-- 3채널 -->
  <section class="container-narrow py-section">
    <div class="grid md:grid-cols-3 gap-5 max-w-5xl mx-auto">
      {channels.map(({ title, body, cta, href, note }) => (
        <a href={href} class="card hover:border-navy-700 transition group block">
          <div class="label-uppercase mb-3">{note}</div>
          <h3 class="text-lg font-bold text-navy-700 mb-3">{title}</h3>
          <p class="text-sm text-ink-muted leading-relaxed whitespace-pre-line mb-5 min-h-[48px]">
            {body}
          </p>
          <div class="pt-4 border-t border-ink-line font-bold text-ink group-hover:text-navy-700">
            {cta} →
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- 오시는 길 -->
  <section class="bg-ink-soft py-section">
    <div class="container-narrow max-w-4xl">
      <p class="label-uppercase text-center mb-3">본사</p>
      <h2 class="text-2xl md:text-3xl font-bold text-navy-700 text-center mb-10">
        오시는 길
      </h2>
      <div class="card">
        <dl class="grid md:grid-cols-2 gap-5 text-sm">
          <div>
            <dt class="text-ink-muted mb-1">주소</dt>
            <dd class="font-semibold text-ink">서울특별시 강남구 학동로8길 9, 5층</dd>
          </div>
          <div>
            <dt class="text-ink-muted mb-1">대표번호</dt>
            <dd class="font-semibold text-ink">
              <a href="tel:1544-4150">1544-4150</a>
            </dd>
          </div>
          <div>
            <dt class="text-ink-muted mb-1">업무시간</dt>
            <dd class="font-semibold text-ink">평일 09:00~18:00 (점심 12:00~13:00)</dd>
          </div>
          <div>
            <dt class="text-ink-muted mb-1">지하철</dt>
            <dd class="font-semibold text-ink">7호선 학동역 · 3호선 압구정역 도보 거리</dd>
          </div>
        </dl>
      </div>
    </div>
  </section>

  <!-- 회사 정보 요약 -->
  <section class="container-narrow py-section max-w-3xl">
    <div class="card text-center">
      <p class="label-uppercase mb-3">회사 정보</p>
      <div class="text-sm text-ink-muted leading-relaxed space-y-1">
        <div>(주)하우스맨 · 대표 박종호</div>
        <div>사업자등록번호 206-16-25497</div>
        <div>서울특별시 강남구 학동로8길 9, 5층</div>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
