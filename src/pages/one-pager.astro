---
// One-Pager — 영업 상담·제안서 첨부용 A4 한 장 요약
// Ctrl+P → PDF로 저장 가능
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="하우스맨 원페이저 | 한 장 요약"
  description="하우스맨을 한 페이지로. A4 한 장 영업 자료. 인쇄 가능."
>
  <div class="no-print">
    <Nav />
    <section class="container-narrow py-12 max-w-4xl">
      <p class="label-uppercase mb-3">원페이저</p>
      <h1 class="text-2xl md:text-3xl font-bold text-navy-700 mb-3">
        하우스맨을 한 장에 담았습니다
      </h1>
      <p class="text-ink-muted leading-relaxed mb-4">
        상담 시·제안서 첨부·대기업 이메일에 붙이는 A4 한 장 요약.
      </p>
      <button onclick="window.print()" class="btn-primary">🖨️ PDF로 인쇄·저장</button>
    </section>
  </div>

  <article class="one-pager">
    <header class="flex justify-between items-start pb-4 border-b-2 border-navy-700 mb-6">
      <div>
        <div class="text-3xl font-extrabold text-navy-700 tracking-tight">HOUSEMAN</div>
        <p class="text-sm text-ink-muted mt-1">건물관리, 이제 네비게이션처럼.</p>
      </div>
      <div class="text-right text-xs text-ink-label">
        (주)하우스맨 · 2012년 설립 · 15년차<br/>
        대표 박종호 · 사업자 206-16-25497
      </div>
    </header>

    <section class="mb-6">
      <h2 class="label-uppercase mb-2">우리는 누구인가</h2>
      <p class="text-sm leading-relaxed">
        서울 강남 기반 15년차 건물관리 전문기업. 주거·상업·단기임대·기업 시설·비상주 관리사무소
        5대 서비스를 운영하며, 자체 SaaS로 청구·수금·정산·알림톡을 완전 자동화합니다.
      </p>
    </section>

    <section class="grid grid-cols-4 gap-3 mb-6">
      <div class="border border-ink-line rounded-lg p-3 text-center">
        <div class="text-[10px] text-ink-label uppercase">관리 건물</div>
        <div class="text-2xl font-extrabold text-navy-700">100+</div>
      </div>
      <div class="border border-ink-line rounded-lg p-3 text-center">
        <div class="text-[10px] text-ink-label uppercase">관리 호실</div>
        <div class="text-2xl font-extrabold text-navy-700">1,100+</div>
      </div>
      <div class="border border-ink-line rounded-lg p-3 text-center">
        <div class="text-[10px] text-ink-label uppercase">부동산 네트워크</div>
        <div class="text-2xl font-extrabold text-navy-700">800+</div>
      </div>
      <div class="border border-ink-line rounded-lg p-3 text-center">
        <div class="text-[10px] text-ink-label uppercase">운영 경력</div>
        <div class="text-2xl font-extrabold text-navy-700">15년</div>
      </div>
    </section>

    <section class="grid grid-cols-2 gap-5 mb-6">
      <div>
        <h2 class="label-uppercase mb-2">5대 서비스</h2>
        <ul class="text-sm space-y-1">
          <li>· 중소형 빌딩 관리</li>
          <li>· 중소형 주택 관리</li>
          <li>· 단기임대 운영 (3개월 100% 수금 보장)</li>
          <li>· 기업 시설 관리 (포르쉐·보건복지부)</li>
          <li>· 비상주 관리사무소 (150세대 미만)</li>
        </ul>
      </div>
      <div>
        <h2 class="label-uppercase mb-2">우리가 다른 이유</h2>
        <ul class="text-sm space-y-1">
          <li>✓ 14년 현장 + 자체 SaaS (업계 유일)</li>
          <li>✓ 24시간 긴급 대응 · 업계 최단급</li>
          <li>✓ 800+ 부동산 네트워크로 공실 최소화</li>
          <li>✓ 중개보수 쉐어 X · 건물주 수익 극대화</li>
          <li>✓ 호실 단위 관리 (주거 원룸부터 사옥까지)</li>
        </ul>
      </div>
    </section>

    <section class="mb-6">
      <h2 class="label-uppercase mb-2">실제 사례</h2>
      <div class="grid grid-cols-3 gap-3 text-xs">
        <div class="border border-ink-line rounded p-3">
          <div class="font-bold text-navy-700 mb-1">18개월 공실 → 14일 만실</div>
          <p class="text-ink-muted">역삼 6층 빌딩</p>
        </div>
        <div class="border border-ink-line rounded p-3">
          <div class="font-bold text-navy-700 mb-1">2년 누적 미납 90% 회수</div>
          <p class="text-ink-muted">10호실 다가구</p>
        </div>
        <div class="border border-ink-line rounded p-3">
          <div class="font-bold text-navy-700 mb-1">10년+ 파트너십</div>
          <p class="text-ink-muted">포르쉐 코리아 사옥</p>
        </div>
      </div>
    </section>

    <section class="mb-6">
      <h2 class="label-uppercase mb-2">요금</h2>
      <div class="grid grid-cols-3 gap-3 text-xs">
        <div class="border border-ink-line rounded p-3">
          <div class="font-bold text-ink mb-1">Starter</div>
          <div class="text-lg font-extrabold text-navy-700">월 30,000원</div>
          <p class="text-ink-muted mt-1">호실 1~10개 · 기본 자동화</p>
        </div>
        <div class="border border-navy-700 rounded p-3 border-2">
          <div class="font-bold text-navy-700 mb-1">Pro ★</div>
          <div class="text-lg font-extrabold text-navy-700">월 50,000원</div>
          <p class="text-ink-muted mt-1">호실 11~50개 · 풀 자동화</p>
        </div>
        <div class="border border-ink-line rounded p-3">
          <div class="font-bold text-ink mb-1">Enterprise</div>
          <div class="text-lg font-extrabold text-navy-700">맞춤</div>
          <p class="text-ink-muted mt-1">50+ 또는 대행 패키지</p>
        </div>
      </div>
    </section>

    <footer class="pt-4 border-t border-ink-line flex justify-between items-end">
      <div class="text-xs text-ink-label leading-relaxed">
        서울 강남구 학동로8길 9, 5층<br/>
        contact@houseman.co.kr
      </div>
      <div class="text-right">
        <div class="text-[10px] text-ink-label uppercase">무료 상담</div>
        <div class="text-2xl font-extrabold text-navy-700">1544-4150</div>
        <div class="text-[10px] text-ink-muted">houseman.co.kr</div>
      </div>
    </footer>
  </article>

  <div class="no-print">
    <Footer />
  </div>

  <style>
    .one-pager {
      max-width: 820px;
      margin: 0 auto 80px;
      padding: 36px 44px;
      background: white;
      box-shadow: 0 10px 30px rgba(0,0,0,0.08);
      border-radius: 8px;
      font-size: 13px;
      color: #111827;
    }
    @media print {
      @page { size: A4; margin: 12mm; }
      body { background: white !important; }
      .no-print { display: none !important; }
      .one-pager { max-width: 100%; margin: 0; padding: 0; box-shadow: none; border-radius: 0; }
    }
  </style>
</BaseLayout>
