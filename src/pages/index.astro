---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import LogoCarousel from '../components/LogoCarousel.astro';
import StatsGrid from '../components/StatsGrid.astro';
import ServiceCardGrid from '../components/ServiceCardGrid.astro';
import OnboardingTeaser from '../components/OnboardingTeaser.astro';
import PainPoint from '../components/PainPoint.astro';
import NavigationMetaphor from '../components/NavigationMetaphor.astro';
import AutomationProcess from '../components/AutomationProcess.astro';
import LiveCounter from '../components/LiveCounter.astro';
import ComparisonTable from '../components/ComparisonTable.astro';
import CaseStudies from '../components/CaseStudies.astro';
import Testimonials from '../components/Testimonials.astro';
import PricingPlans from '../components/PricingPlans.astro';
import RiskList from '../components/RiskList.astro';
import FAQ from '../components/FAQ.astro';
import FinalCTA from '../components/FinalCTA.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="하우스맨 OS — 당신 건물의 운영체제"
  description="범용 SaaS가 못한 걸, 하우스맨 OS는 합니다. 15년 현장 경험 + 질문지 기반 맞춤 세팅. 100+ 건물 1,100+ 호실. 포르쉐·보건복지부 선택."
>
  <Nav />

  <main>
    <Hero />
    <LogoCarousel />
    <StatsGrid />
    <ServiceCardGrid />
    <OnboardingTeaser />
    <PainPoint />
    <NavigationMetaphor />
    <AutomationProcess />
    <LiveCounter />
    <ComparisonTable />
    <CaseStudies />
    <Testimonials />
    <PricingPlans />
    <RiskList />
    <FAQ />
    <FinalCTA />
  </main>

  <Footer />
</BaseLayout>
