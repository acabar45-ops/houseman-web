---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const APP_URL = 'https://app.houseman.co.kr'; // SaaS 정식 런칭 시 실제 URL
---

<BaseLayout
  title="로그인 | 하우스맨 SaaS"
  description="하우스맨 SaaS 로그인. 건물주·담당자 전용."
>
  <Nav />

  <section class="container-narrow py-section max-w-md">
    <div class="card text-center">
      <p class="label-uppercase mb-3">SaaS 로그인</p>
      <h1 class="text-2xl font-bold text-navy-700 mb-4">
        하우스맨 SaaS에 오신 걸 환영합니다
      </h1>
      <p class="text-sm text-ink-muted mb-8 leading-relaxed">
        건물주·관리 담당자 전용 대시보드입니다.<br/>
        아래 버튼으로 SaaS 앱에 접속하세요.
      </p>

      <a href={APP_URL} class="btn-primary w-full justify-center mb-3">
        앱으로 이동하기 →
      </a>

      <p class="text-xs text-ink-label mb-8">
        로그인에 문제가 있으면 <a href="mailto:support@houseman.co.kr" class="underline">support@houseman.co.kr</a>
      </p>

      <div class="pt-6 border-t border-ink-line text-left">
        <p class="label-uppercase mb-3">처음 이용하세요?</p>
        <ul class="space-y-2 text-sm text-ink-muted">
          <li>· <a href="/pricing" class="hover:text-navy-700">요금제 보기</a> → 14일 무료 체험</li>
          <li>· <a href="/saas" class="hover:text-navy-700">SaaS가 뭔지 먼저 알아보기</a></li>
          <li>· <a href="tel:1544-4150" class="hover:text-navy-700">1544-4150 상담 신청</a></li>
        </ul>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
