---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { vacancies } from '../../data/vacancies.ts';

const categories = ['전체', '단기', '근생', '주택'] as const;

const counts: Record<string, number> = {
  전체: vacancies.length,
  단기: vacancies.filter((v) => v.category === '단기').length,
  근생: vacancies.filter((v) => v.category === '근생').length,
  주택: vacancies.filter((v) => v.category === '주택').length,
};
---

<BaseLayout
  title="공실 정보 | 하우스맨"
  description="하우스맨 관리 건물 중 현재 비어있는 호실을 실시간 공개합니다. 단기·근생·주택 카테고리별 필터."
>
  <Nav />

  <section class="bg-hero-gradient text-white py-20">
    <div class="container-narrow text-center max-w-3xl">
      <p class="label-uppercase text-white/70 mb-4">공실 정보</p>
      <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight mb-5">
        지금 비어있는 호실 {vacancies.length}개.
      </h1>
      <p class="text-lg text-white/85 leading-relaxed">
        하우스맨 관리 건물의 공실을 실시간 공개합니다. 카톡 한 번으로 상담 시작.
      </p>
    </div>
  </section>

  <!-- 카테고리 필터 (클라이언트 JS 작동) -->
  <section class="container-narrow pt-14">
    <div class="flex flex-wrap justify-center gap-3 mb-10">
      {categories.map((cat, i) => (
        <button
          type="button"
          data-filter={cat}
          class={`filter-btn px-5 py-2 rounded-full text-sm font-semibold border transition ${
            i === 0 ? 'active bg-navy-700 text-white border-navy-700' : 'border-ink-line text-ink-muted'
          }`}
        >
          {cat} <span class="ml-1 text-xs opacity-70">({counts[cat] ?? 0})</span>
        </button>
      ))}
    </div>
  </section>

  <!-- 공실 목록 -->
  <section class="container-narrow pb-section">
    <div id="vacancy-grid" class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
      {vacancies.map((v) => (
        <article
          data-category={v.category}
          class="vacancy-card card hover:border-navy-700 transition flex flex-col"
        >
          <div class="flex items-center justify-between mb-3">
            <span class={`label-uppercase ${v.category === '단기' ? 'text-emphasis' : 'text-navy-700'}`}>
              {v.category}
            </span>
            <span class="text-xs text-ink-label">{v.area}</span>
          </div>
          <h3 class="text-lg font-bold text-ink mb-1">{v.building}</h3>
          <p class="text-sm text-ink-muted mb-3">{v.room} · {v.layout} · {v.areaSize}</p>
          {v.highlight && (
            <p class="text-xs text-ink-muted italic mb-3">"{v.highlight}"</p>
          )}
          <div class="pt-4 border-t border-ink-line flex items-baseline gap-4 mt-auto">
            <div>
              <div class="text-[11px] text-ink-label mb-1">보증금</div>
              <div class="font-bold text-ink">{v.deposit.toLocaleString()}만</div>
            </div>
            <div>
              <div class="text-[11px] text-ink-label mb-1">월세</div>
              <div class="font-bold text-navy-700">{v.rent}만</div>
            </div>
          </div>
          <div class="flex gap-2 mt-4">
            <a
              href={`/vacancies/${v.slug}`}
              class="flex-1 text-center py-2 text-sm font-semibold text-navy-700 border border-navy-700 rounded hover:bg-navy-700 hover:text-white transition"
            >
              자세히
            </a>
            <a
              href="https://pf.kakao.com/_hYmxjn/chat"
              target="_blank"
              rel="noopener"
              class="flex-1 text-center py-2 text-sm font-semibold bg-navy-700 text-white rounded hover:bg-navy-800 transition"
            >
              카톡 상담
            </a>
          </div>
        </article>
      ))}
    </div>

    <p id="empty-state" class="hidden text-center py-20 text-ink-muted">
      이 카테고리에는 현재 공실이 없습니다.<br/>
      <a href="https://pf.kakao.com/_hYmxjn/chat" target="_blank" rel="noopener"
         class="inline-block mt-4 btn-primary">
        대기자 등록 요청
      </a>
    </p>

    <p class="text-center text-xs text-ink-label mt-10">
      기준일: 2026-04 · 변동 가능 (카톡 상담 시 최신 상태 확인)
    </p>
  </section>

  <Footer />

  <script is:inline>
    const buttons = document.querySelectorAll('.filter-btn');
    const cards = document.querySelectorAll('.vacancy-card');
    const emptyState = document.getElementById('empty-state');

    function apply(filter) {
      let visible = 0;
      cards.forEach((card) => {
        const match = filter === '전체' || card.dataset.category === filter;
        card.style.display = match ? '' : 'none';
        if (match) visible++;
      });
      if (emptyState) {
        emptyState.classList.toggle('hidden', visible > 0);
      }
    }

    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        buttons.forEach((b) => {
          b.classList.remove('active', 'bg-navy-700', 'text-white', 'border-navy-700');
          b.classList.add('border-ink-line', 'text-ink-muted');
        });
        btn.classList.add('active', 'bg-navy-700', 'text-white', 'border-navy-700');
        btn.classList.remove('border-ink-line', 'text-ink-muted');
        apply(btn.dataset.filter);
      });
    });
  </script>
</BaseLayout>
