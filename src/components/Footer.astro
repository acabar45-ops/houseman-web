---
// 푸터 — Stripe급 정보 밀도 + 사업자정보 전면 공개 (AEO 신뢰 신호)
import NewsletterForm from './NewsletterForm.astro';
const currentYear = new Date().getFullYear();
---

<footer class="border-t border-ink-line bg-ink-soft">
  <!-- 뉴스레터 배너 -->
  <div class="border-b border-ink-line bg-white">
    <div class="container-narrow py-10 grid md:grid-cols-2 gap-6 items-center">
      <div>
        <p class="label-uppercase mb-2">뉴스레터</p>
        <h3 class="text-xl md:text-2xl font-bold text-navy-700 leading-tight">
          건물관리 실무 요약을<br class="md:hidden"/> 월 1회 이메일로.
        </h3>
        <p class="text-sm text-ink-muted mt-2">
          미납 대응·세무·공실 전략·업계 뉴스. 광고 없음.
        </p>
      </div>
      <NewsletterForm />
    </div>
  </div>

  <div class="container-narrow py-16 grid md:grid-cols-5 gap-8">
    <!-- 브랜드 -->
    <div class="md:col-span-2">
      <div class="text-xl font-extrabold text-navy-700 mb-3">HOUSEMAN</div>
      <p class="text-sm text-ink-muted leading-relaxed">
        2012년 설립, 서울 강남 기반<br/>
        15년차 건물관리 전문기업.
      </p>
      <div class="mt-5 text-sm text-ink-muted space-y-1">
        <div>대표 박종호 · 사업자 206-16-25497</div>
        <div>서울시 강남구 학동로8길 9, 5층</div>
        <div>
          <a href="tel:1544-4150" class="hover:text-navy-700">1544-4150</a> ·
          <a href="mailto:contact@houseman.co.kr" class="hover:text-navy-700">contact@houseman.co.kr</a>
        </div>
      </div>
    </div>

    <!-- 서비스 -->
    <div>
      <div class="label-uppercase mb-4">서비스</div>
      <ul class="space-y-2 text-sm">
        <li><a href="/services/buildings" class="text-ink-muted hover:text-navy-700">중소형 빌딩</a></li>
        <li><a href="/services/housing" class="text-ink-muted hover:text-navy-700">중소형 주택</a></li>
        <li><a href="/services/short-term" class="text-ink-muted hover:text-navy-700">단기임대</a></li>
        <li><a href="/services/corporate" class="text-ink-muted hover:text-navy-700">기업 시설</a></li>
        <li><a href="/services/non-resident" class="text-ink-muted hover:text-navy-700">비상주 관리사무소</a></li>
      </ul>
    </div>

    <!-- 회사 -->
    <div>
      <div class="label-uppercase mb-4">회사</div>
      <ul class="space-y-2 text-sm">
        <li><a href="/about" class="text-ink-muted hover:text-navy-700">회사소개</a></li>
        <li><a href="/cases" class="text-ink-muted hover:text-navy-700">케이스 스터디</a></li>
        <li><a href="/blog" class="text-ink-muted hover:text-navy-700">블로그</a></li>
        <li><a href="/contact" class="text-ink-muted hover:text-navy-700">문의</a></li>
      </ul>
    </div>

    <!-- 리소스 -->
    <div>
      <div class="label-uppercase mb-4">리소스</div>
      <ul class="space-y-2 text-sm">
        <li><a href="/vacancies" class="text-ink-muted hover:text-navy-700">공실 정보</a></li>
        <li><a href="/pricing" class="text-ink-muted hover:text-navy-700">요금제</a></li>
        <li><a href="/saas" class="text-ink-muted hover:text-navy-700">SaaS 플랫폼</a></li>
        <li><a href="/cases" class="text-ink-muted hover:text-navy-700">케이스 스터디</a></li>
        <li><a href="/compare" class="text-ink-muted hover:text-navy-700">경쟁사 비교</a></li>
        <li><a href="/tools/calculator" class="text-ink-muted hover:text-navy-700">수익 계산기</a></li>
        <li><a href="/samples/monthly-report" class="text-ink-muted hover:text-navy-700">월간 리포트 샘플</a></li>
        <li><a href="/resources" class="text-ink-muted hover:text-navy-700">자료실</a></li>
        <li><a href="/contact" class="text-ink-muted hover:text-navy-700">문의</a></li>
      </ul>

      <!-- SNS 채널 -->
      <div class="label-uppercase mt-6 mb-3">채널</div>
      <div class="flex items-center gap-2">
        <a
          href="https://pf.kakao.com/_hYmxjn/chat"
          target="_blank"
          rel="noopener"
          aria-label="카카오톡 채널"
          title="카카오톡 채널"
          class="w-9 h-9 flex items-center justify-center rounded-full border border-ink-line hover:border-navy-700 hover:bg-navy-700 hover:text-white transition text-ink-muted"
        >
          <!-- 카카오톡 말풍선 아이콘 -->
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 3C6.48 3 2 6.57 2 10.97c0 2.88 1.95 5.4 4.85 6.81-.14.5-.89 3.09-.92 3.29 0 0-.02.17.09.23.11.07.24.01.24.01.28-.04 3.27-2.13 3.79-2.49.63.09 1.29.14 1.95.14 5.52 0 10-3.57 10-7.97C22 6.57 17.52 3 12 3z"/>
          </svg>
        </a>
        <a
          href="https://blog.naver.com/houseman842"
          target="_blank"
          rel="noopener"
          aria-label="네이버 블로그"
          title="네이버 블로그"
          class="w-9 h-9 flex items-center justify-center rounded-full border border-ink-line hover:border-navy-700 hover:bg-navy-700 hover:text-white transition text-ink-muted font-bold text-xs"
        >
          N
        </a>
        <a
          href="https://www.instagram.com/"
          target="_blank"
          rel="noopener"
          aria-label="인스타그램"
          title="인스타그램 (준비 중)"
          class="w-9 h-9 flex items-center justify-center rounded-full border border-ink-line hover:border-navy-700 hover:bg-navy-700 hover:text-white transition text-ink-muted"
        >
          <!-- 인스타그램 아이콘 -->
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
            <path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"></path>
            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
          </svg>
        </a>
      </div>
    </div>
  </div>

  <div class="border-t border-ink-line">
    <div class="container-narrow py-6 flex flex-wrap justify-between gap-3 text-xs text-ink-label">
      <div>© {currentYear} (주)하우스맨. All rights reserved.</div>
      <div class="flex gap-5">
        <a href="/privacy" class="hover:text-navy-700">개인정보처리방침</a>
        <a href="/terms" class="hover:text-navy-700">이용약관</a>
      </div>
    </div>
  </div>
</footer>
