---
// FAQ 7개 (클리니어 벤치마킹)
const faqs = [
  {
    q: '수수료는 얼마인가요?',
    a: 'SaaS는 월 3만원부터 공개된 3단 플랜으로 선택하실 수 있습니다. 대행 서비스는 건물 크기·유형·서비스 범위에 따라 맞춤 견적이 필요합니다. 1544-4150으로 연락 주시면 15분 내 예상 견적을 드립니다.',
  },
  {
    q: '건물 몇 개부터 맡길 수 있나요?',
    a: '1호실부터 가능합니다. 원룸 1개, 오피스텔 1채 같은 소규모부터 100+ 호실 빌딩까지 모두 운영합니다.',
  },
  {
    q: '긴급 상황은 얼마나 빨리 대응하나요?',
    a: '서울 전역 24시간 긴급 대응 체계를 운영합니다. 누수·단전·입주민 분쟁 등 평균 대응 시간은 업계 최단 수준입니다.',
  },
  {
    q: '계약 해지는 자유로운가요?',
    a: 'SaaS는 월 단위 구독이므로 언제든 해지 가능합니다. 대행 서비스는 최소 3개월 이후 1개월 전 통보로 해지 가능합니다.',
  },
  {
    q: '포르쉐·보건복지부는 어떤 서비스를 쓰나요?',
    a: '기업 시설 관리 패키지를 쓰십니다. 시설 유지보수 + 경비·미화 + 에너지 점검 + 법정 이력 관리까지 통합 위탁 형태입니다.',
  },
  {
    q: 'SaaS만 쓸 수도 있나요?',
    a: '가능합니다. 건물주가 직접 관리하시면서 청구·수금·알림톡·정산만 자동화하고 싶으시면 SaaS 플랜만 선택하시면 됩니다.',
  },
  {
    q: '지방도 관리되나요?',
    a: '현재 서울 전역이 주력 지역입니다. 지방 건물은 상담 후 개별 검토합니다. SaaS는 지역 무관하게 바로 사용 가능합니다.',
  },
] as const;
---

<section class="bg-ink-soft py-section">
  <div class="container-narrow max-w-3xl">
    <div class="text-center mb-12">
      <p class="label-uppercase mb-3">자주 묻는 질문</p>
      <h2 class="text-3xl md:text-4xl font-bold text-navy-700">FAQ</h2>
    </div>

    <div class="space-y-3">
      {faqs.map(({ q, a }) => (
        <details class="card group">
          <summary class="flex items-center justify-between cursor-pointer list-none">
            <span class="font-semibold text-ink text-left pr-4">{q}</span>
            <span class="text-navy-700 text-xl transition-transform group-open:rotate-45 flex-shrink-0">
              +
            </span>
          </summary>
          <p class="mt-4 text-ink-muted leading-relaxed text-[15px]">{a}</p>
        </details>
      ))}
    </div>

    <!-- AEO용 FAQPage JSON-LD -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'FAQPage',
        mainEntity: faqs.map(({ q, a }) => ({
          '@type': 'Question',
          name: q,
          acceptedAnswer: { '@type': 'Answer', text: a },
        })),
      })}
    ></script>
  </div>
</section>
