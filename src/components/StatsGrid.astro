---
// StatsGrid — Stripe 큰 숫자 스타일 (카운트업 + 2×2/4×1 그리드)
//
// CMS (app_settings.homepage_content) 에서 stat1~4Num 을 받아 숫자 치환.
// 원본 SaaS 기본값: 15 / 100 / 800 / 98 — 라이프스타일상 label/sublabel 은
// Astro 의 Stripe 스타일("관리 건물 · 서울 전역" 등)을 그대로 유지하고,
// CMS 는 **숫자만** 덮어쓴다 (디자인 안전).
export interface Props {
  stat1Num?: string;
  stat2Num?: string;
  stat3Num?: string;
  stat4Num?: string;
}
const {
  stat1Num,
  stat2Num,
  stat3Num,
  stat4Num,
} = Astro.props as Props;

// CMS 값을 숫자로 변환 — 실패 시 Astro 기본 target 유지
const toNum = (v: string | undefined, fallback: number): number => {
  if (!v) return fallback;
  const n = parseInt(String(v).replace(/[^0-9]/g, ''), 10);
  return Number.isFinite(n) && n > 0 ? n : fallback;
};

const stats = [
  { target: toNum(stat2Num, 100),  suffix: '+', label: '관리 건물',       sublabel: '서울 전역' },
  { target: 1100,                   suffix: '+', label: '관리 호실',       sublabel: '주거·상업 복합' },
  { target: toNum(stat3Num, 800),  suffix: '+', label: '부동산 네트워크', sublabel: '공실 매칭' },
  { target: toNum(stat1Num, 15),   suffix: '년', label: '운영 경험',       sublabel: '2012년 설립' },
] as const;
// 주: stat4Num(입주율 98%)은 현재 Astro StatsGrid 레이아웃에 슬롯이
//     없음(호실 1,100+ 가 이미 4번째). 필요 시 후속 PR 에서 섹션 추가.

const baseDate = '2026-04';
---

<section class="bg-ink-soft">
  <div class="container-narrow py-section">
    <div class="text-center mb-14">
      <p class="eyebrow mb-3">15년 현장, OS의 토대</p>
      <h2 class="font-display text-h2 text-ink">
        OS 뒤엔 1,100+ 호실의 실전이 있습니다.
      </h2>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-5 max-w-content-wide mx-auto">
      {stats.map(({ target, suffix, label, sublabel }) => (
        <div class="bg-white border border-ink-line rounded-card-lg p-8 md:p-10 text-center shadow-card">
          <div
            class="stat-number font-display text-[44px] md:text-[56px] font-extrabold text-ink leading-none tracking-tight mb-3"
            data-target={target}
            data-suffix={suffix}
          >
            0{suffix}
          </div>
          <div class="text-body font-semibold text-ink">{label}</div>
          <div class="text-sm text-ink-label mt-1">{sublabel}</div>
        </div>
      ))}
    </div>

    <p class="mt-8 text-center text-[11px] text-ink-label tracking-wider uppercase">
      기준: {baseDate}
    </p>
  </div>
</section>

<script is:inline>
  const nodes = document.querySelectorAll('.stat-number');
  if (nodes.length && 'IntersectionObserver' in window) {
    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (!entry.isIntersecting) continue;
          const el = entry.target;
          const target = Number(el.dataset.target);
          const suffix = el.dataset.suffix || '';
          const duration = 1600;
          const start = performance.now();
          const tick = (now) => {
            const p = Math.min(1, (now - start) / duration);
            const eased = 1 - Math.pow(1 - p, 3);
            const current = Math.round(target * eased);
            el.textContent = current.toLocaleString() + suffix;
            if (p < 1) requestAnimationFrame(tick);
          };
          requestAnimationFrame(tick);
          observer.unobserve(el);
        }
      },
      { threshold: 0.3 },
    );
    nodes.forEach((n) => observer.observe(n));
  } else {
    nodes.forEach((n) => {
      const target = Number(n.dataset.target);
      n.textContent = target.toLocaleString() + (n.dataset.suffix || '');
    });
  }
</script>
