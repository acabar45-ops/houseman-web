---
// 고객 후기 3개 (클리니어 스타일 — 건물·포지션 + 한 줄 코멘트)
// Phase 1 Week 2에 실제 후기로 교체
const quotes = [
  {
    quote: '매달 월세 수금 때문에 휴대폰 보기가 싫었는데, 이제는 월말 정산 리포트 한 번만 확인하면 됩니다.',
    who: '강남구 A빌라 건물주',
    context: '관리 호실 24개',
  },
  {
    quote: '기업 시설 관리 위탁 전후의 차이가 확실합니다. 우리 직원이 시설에 신경 안 써도 됩니다.',
    who: '포르쉐 코리아 사옥 관리팀',
    context: '기업 시설 관리',
  },
  {
    quote: '단기임대로 바꾸고 연 수익이 분명히 늘었습니다. 하우스맨이 3개월 계약 수금 보장까지 해주니 안심.',
    who: '서초구 B오피스텔 건물주',
    context: '단기임대 전환',
  },
] as const;
---

<section class="container-narrow py-section">
  <div class="text-center mb-12">
    <p class="label-uppercase mb-3">고객 후기</p>
    <h2 class="text-3xl md:text-4xl font-bold text-navy-700">
      건물주분들이 직접 말씀해주셨습니다.
    </h2>
  </div>

  <div class="grid md:grid-cols-3 gap-5">
    {quotes.map(({ quote, who, context }) => (
      <figure class="card h-full flex flex-col">
        <blockquote class="text-ink leading-relaxed flex-1 text-[15px]">
          "{quote}"
        </blockquote>
        <figcaption class="mt-5 pt-4 border-t border-ink-line">
          <div class="font-bold text-navy-700 text-sm">{who}</div>
          <div class="text-xs text-ink-muted mt-1">{context}</div>
        </figcaption>
      </figure>
    ))}
  </div>
</section>
